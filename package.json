{
  "name": "claude-plan-review",
  "version": "0.1.1",
  "description": "Review, comment on, and approve/reject Claude Code plans in a local GitHub-style web UI — with persistent comments, version history, and diffs.",
  "type": "module",
  "bin": {
    "claude-plan-review": "src/cli.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "serve": "node src/server.js",
    "hook": "node src/hook.js",
    "stop": "node src/cli.js stop"
  },
  "dependencies": {
    "marked": "^14.1.3"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.1.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "plan",
    "plan-mode",
    "code-review",
    "hooks",
    "exitplanmode"
  ],
  "homepage": "https://github.com/pavlo-petrychenko/claude-plan-preview-local#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pavlo-petrychenko/claude-plan-preview-local.git"
  },
  "bugs": {
    "url": "https://github.com/pavlo-petrychenko/claude-plan-preview-local/issues"
  },
  "author": "pavlo.p@mate.academy",
  "license": "MIT"
}
